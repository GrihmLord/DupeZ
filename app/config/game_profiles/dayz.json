{
  "schema": "dupez.game-profile.v2",
  "game": "DayZ",
  "engine": "Enfusion",
  "purpose": "Passive DayZ connectivity diagnostics and authorized local-lab network-condition reproduction.",
  "safety_boundary": {
    "owned_or_authorized_scope_required": true,
    "detection_avoidance": false,
    "unauthorized_public_server_use": false,
    "game_state_manipulation": false
  },
  "network": {
    "protocol": "udp",
    "default_port": 2302,
    "port_range": [
      2302,
      2305
    ],
    "query_ports": [
      27015,
      27016,
      27017
    ],
    "auxiliary_ports": [
      9306,
      9308
    ],
    "all_known_ports": [
      2302,
      2303,
      2304,
      2305,
      9306,
      9308,
      27015,
      27016,
      27017
    ],
    "port_auto_detect": true,
    "port_auto_detect_method": "highest_pps_udp_flow"
  },
  "passive_diagnostics": {
    "server_reachability": true,
    "query_health": true,
    "latency_ms": true,
    "jitter_ms": true,
    "loss_percent": true,
    "route_summary": true,
    "adapter_readiness": true,
    "firewall_hinting": true,
    "private_server_config_review": true
  },
  "packet_classification": {
    "auto_calibrate": true,
    "calibration_duration_sec": 8,
    "size_thresholds": {
      "keepalive_max_bytes": 60,
      "movement_max_bytes": 150,
      "state_max_bytes": 500,
      "bulk_min_bytes": 500
    },
    "frequency_thresholds": {
      "high_pps": 25,
      "medium_pps": 5,
      "low_pps": 5
    }
  },
  "disruption_defaults": {
    "lag_delay_ms": 250,
    "drop_chance_pct": 2,
    "disconnect_chance_pct": 100,
    "bandwidth_limit_kbps": 256,
    "bandwidth_queue": 0,
    "throttle_chance_pct": 100,
    "direction": "both",
    "max_duration_sec": 300,
    "notes": "Compatibility defaults for authorized local-lab network-condition scenarios."
  },
  "disruption_presets": {
    "pc_local": {
      "_network_local": true,
      "description": "Private local PC lab: mild packet loss and jitter.",
      "methods": [
        "drop",
        "lag"
      ],
      "drop_chance": 2,
      "lag_delay": 250,
      "direction": "both",
      "max_duration_sec": 300
    },
    "ps5_hotspot": {
      "_network_local": false,
      "description": "Operator-owned console hotspot lab: inbound-focused jitter observation.",
      "methods": [
        "lag"
      ],
      "lag_delay": 250,
      "direction": "inbound",
      "max_duration_sec": 300
    },
    "xbox_hotspot": {
      "_network_local": false,
      "description": "Operator-owned Xbox hotspot lab: inbound-focused jitter observation.",
      "methods": [
        "lag"
      ],
      "lag_delay": 250,
      "direction": "inbound",
      "max_duration_sec": 300
    }
  },
  "authorized_lab_presets": {
    "pc_local_light_loss": {
      "_network_local": true,
      "description": "Mild loss profile for a private local PC lab.",
      "methods": [
        "drop"
      ],
      "drop_chance": 2,
      "direction": "both",
      "max_duration_sec": 300
    },
    "console_hotspot_jitter": {
      "_network_local": false,
      "description": "Jitter/latency profile for an operator-owned console hotspot lab.",
      "methods": [
        "lag"
      ],
      "lag_delay": 250,
      "jitter_ms": 100,
      "direction": "both",
      "max_duration_sec": 300
    },
    "bandwidth_pressure": {
      "_network_local": true,
      "description": "Constrained bandwidth profile for private-server troubleshooting.",
      "methods": [
        "bandwidth"
      ],
      "bandwidth_limit_kbps": 256,
      "direction": "both",
      "max_duration_sec": 300
    },
    "short_disconnect": {
      "_network_local": true,
      "description": "Short interruption profile for validating client reconnect behavior in a private lab.",
      "methods": [
        "disconnect"
      ],
      "disconnect_duration_ms": 1000,
      "direction": "both",
      "max_duration_sec": 60
    }
  },
  "platform_support": {
    "pc": {
      "connection_method": "local",
      "diagnostic_layer": "NETWORK",
      "notes": "Local process/device diagnostics only."
    },
    "console_hotspot": {
      "connection_method": "operator_owned_hotspot",
      "diagnostic_layer": "NETWORK_FORWARD",
      "requires_authorized_scope": true
    },
    "wifi_same_network": {
      "connection_method": "owned_or_authorized_lan",
      "diagnostic_layer": "NETWORK_FORWARD",
      "requires_npcap": true,
      "requires_authorized_scope": true
    }
  },
  "a2s_probe": {
    "enabled_by_default": true,
    "default_query_port": 27016,
    "interval_s": 1.0,
    "timeout_s": 1.0,
    "include_roster": false,
    "notes": "Source A2S_INFO polling is used only for passive reachability/query-health reporting. Player roster collection is disabled by default."
  },
  "reporting": {
    "redact_raw_targets": true,
    "redact_mac_addresses": true,
    "operator_note_review_required": true,
    "metrics": [
      "latency_ms",
      "jitter_ms",
      "loss_percent",
      "duration_sec"
    ]
  }
}
