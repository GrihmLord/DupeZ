{
  "schema": "dupez.dayz-connection-diagnostics.v1",
  "game": "DayZ",
  "purpose": "Passive connection diagnostics and authorized local-lab network-condition scenarios.",
  "safety_boundary": {
    "authorized_scope_required": true,
    "prohibited_detection_bypass": false,
    "notes": "This profile is for reproducing latency, jitter, packet loss, bandwidth pressure, route, NAT, firewall, and adapter issues on systems and private servers the operator owns or is explicitly authorized to test.",
    "unauthorized_public_server_use": false,
    "game_state_manipulation": false
  },
  "network_profile": {
    "protocol": "udp",
    "default_game_port": 2302,
    "common_game_port_range": [
      2302,
      2305
    ],
    "common_query_ports": [
      27015,
      27016,
      27017
    ],
    "auxiliary_ports": [
      9306,
      9308
    ],
    "port_auto_detect": true,
    "port_auto_detect_method": "highest_pps_udp_flow"
  },
  "passive_diagnostics": {
    "server_reachability": true,
    "a2s_query_health": true,
    "latency_ms": true,
    "jitter_ms": true,
    "loss_percent": true,
    "adapter_readiness": true,
    "route_summary": true,
    "firewall_hinting": true,
    "pktmon_guided_capture": true
  },
  "authorized_lab_scenarios": {
    "light_loss": {
      "description": "Reproduce mild packet loss in a private lab.",
      "methods": [
        "drop"
      ],
      "drop_chance_pct": 2,
      "max_duration_sec": 300
    },
    "jitter_spikes": {
      "description": "Reproduce intermittent latency spikes in a private lab.",
      "methods": [
        "lag"
      ],
      "lag_delay_ms": 250,
      "jitter_ms": 100,
      "max_duration_sec": 300
    },
    "bandwidth_pressure": {
      "description": "Reproduce constrained uplink/downlink conditions in a private lab.",
      "methods": [
        "bandwidth"
      ],
      "bandwidth_limit_kbps": 256,
      "max_duration_sec": 300
    },
    "temporary_disconnect": {
      "description": "Reproduce a short, operator-reviewed connectivity interruption in a private lab.",
      "methods": [
        "disconnect"
      ],
      "disconnect_duration_ms": 1000,
      "max_duration_sec": 60
    }
  },
  "reporting": {
    "default_report_schema": "dupez.scenario-report.v1",
    "redact_raw_targets": true,
    "redact_mac_addresses": true,
    "include_operator_notes": "review_required",
    "recommended_metrics": [
      "latency_ms",
      "jitter_ms",
      "loss_percent",
      "duration_sec"
    ]
  },
  "retention": {
    "captures_days": 7,
    "reports_days": 30,
    "support_bundles_days": 14
  },
  "version": "3.0.0",
  "last_updated": "2026-06-26T00:00:00Z"
}
