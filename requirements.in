#     scripts\lock-requirements.ps1    (Windows)
#     scripts/lock-requirements.sh     (POSIX)
#
# CI will reject PRs whose requirements.in and requirements-locked.txt
# are out of sync (see .github/workflows/requirements-lock.yml).

