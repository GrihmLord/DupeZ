# DupeZ environment variables — copy to .env and fill in real values
# .env is gitignored; this template is safe to commit.

# ---------------------------------------------------------------------------
# LLM advisor (optional)
# ---------------------------------------------------------------------------
# First-run value is migrated into the encrypted secrets store by
# app/core/secrets_manager.py, after which this env var is no longer needed.
DUPEZ_LLM_API_KEY=sk-your-key-here

# ---------------------------------------------------------------------------
# Code signing (release builds only)
# ---------------------------------------------------------------------------
DUPEZ_SIGN_CERT=path\to\cert.pfx
DUPEZ_SIGN_PASS=your-signing-password
DUPEZ_SIGN_PRIVKEY=path\to\dupez-update-priv.pem
DUPEZ_SIGN_TIMESTAMP_URL=http://timestamp.digicert.com
# Optional override; standard Windows SDK x64 paths are discovered automatically.
# DUPEZ_SIGNTOOL=C:\Program Files (x86)\Windows Kits\10\bin\<version>\x64\signtool.exe

# ---------------------------------------------------------------------------
# Hardware smoketest overrides (used by tests/test_hardware_smoketest.py
# and .github/workflows/hardware-smoketest.yml)
# ---------------------------------------------------------------------------
DUPEZ_SMOKETEST_CIDR=192.168.137.0/24
DUPEZ_SMOKETEST_TARGET_IP=192.168.137.42
DUPEZ_SMOKETEST_TARGET_MAC=00:11:22:33:44:55
DUPEZ_SMOKETEST_LAG_MS=150
DUPEZ_SMOKETEST_DURATION=5
